# ============================================================
# InfraEduca · Variables de entorno
# ============================================================

# Puedes dejar este por defecto de momento para que no de error al cargar el backend
GOOGLE_CLIENT_ID=123456789-ejemplo.apps.googleusercontent.com

# Pon AQUÍ tu correo de Gmail real (en minúsculas) para que el sistema te reconozca como administrador
ADMIN_EMAIL=esmeraldamaricielo123@gmail.com

# Clave secreta local para tus cookies de sesión
SECRET_KEY=clave_secreta_local_para_pruebas_infraeduca_123

# El origen desde el que vas a visualizar tu index.html. 
# Si usas la extensión "Live Server" de VS Code suele ser el 5500. Si lo abres directo o con Flask, déjalo así por ahora.
FRONTEND_ORIGIN=http://127.0.0.1:5500

# Muy importante mantenerlo en "development" para que te permita usar HTTP local sin exigir SSL/HTTPS
FLASK_ENV=development

# Puerto del backend
PORT=5000
